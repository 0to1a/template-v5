PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/template_v5?sslmode=disable
JWT_SECRET=replace-with-at-least-32-random-bytes
# Optional. Leave empty to disable login-code email delivery.
MAIL_URL=smtp://user:password@localhost:1025
# Optional. Set to 1 to auto-register a new active user when RequestLogin is
# called with an email that has no account yet. Leave unset (or 0) to keep
# today's behavior: unrecognized emails receive no account and no code.
IS_GUEST_REGISTRATION=0
# Optional. "development" or "production" (any other value fails startup).
# Defaults to "production" when unset. Only "development" allows the seeded
# admin@localhost account to log in with the fixed code "123456" — set this
# to "development" for local work, and leave it unset (or "production") in
# every real deployment.
APP_ENV=development
